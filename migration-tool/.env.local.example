# Copy to .env.local for local development:  cp .env.local.example .env.local
# In production, set these directly in the Vercel dashboard
# (Project Settings -> Environment Variables) — never commit real values,
# and never paste real values into a chat/AI assistant.

# bcrypt hash of the shared login password. Generate with:
#   npm run hash-password -- "your-password-here"
AUTH_PASSWORD_HASH=

# Random secret (32+ bytes) used to sign the session cookie. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# One hosting account, used for every migration regardless of domain —
# read these off your hosting panel's SSH access page. Easier to fill in
# from the app's Settings page once you're logged in than by hand here.
SSH_HOST=
SSH_USERNAME=
SSH_PORT=

# Full PEM private key that connects to the account above (the one that
# already works with `ssh <that-host>` locally, e.g. ~/.ssh/id_ed25519).
# Paste with real newlines (not \n-escaped).
SSH_PRIVATE_KEY=

# Only needed if the key above has a passphrase.
SSH_PRIVATE_KEY_PASSPHRASE=

# Alternative to the key above, if this host allows SSH password login
# (many managed hosts, e.g. SiteGround, don't) — SSH_PRIVATE_KEY takes
# priority automatically whenever both are set, so leave this blank if
# you're using a key.
SSH_PASSWORD=
